---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import AdSlot from '../components/AdSlot.astro';
import lookbookData from '../data/lookbook.json';

// Get unique categories for reference
const categories = [...new Set(lookbookData.map(item => item.category))];
---

<Layout 
  title="Élévation — Luxury Minimalist Lookbook"
  description="Explore the curated lookbook of luxury minimal accessories, designer card cases, and ribbed midi dresses."
>
  <!-- Hero Header Section -->
  <header class="max-w-5xl mx-auto text-center pt-20 pb-8 px-6">
    <div class="animate-fade-in-up flex flex-col items-center">
      <span class="text-[9px] tracking-[0.35em] uppercase text-terracotta font-semibold mb-4 block">
        Collection I / The Selection
      </span>
      <h1 class="font-serif text-5xl md:text-7xl font-normal leading-[1.05] tracking-tight text-text max-w-3xl">
        L'Estetica Italiana
      </h1>
      <div class="w-12 h-[1px] bg-terracotta/40 my-8"></div>
      <p class="font-sans text-[10px] md:text-xs text-text/60 max-w-lg leading-relaxed tracking-[0.2em] uppercase">
        A study in structural tailoring, luxury leather curation, and fine ribbed knits.
        <br />
        <span class="normal-case italic text-[11px] block mt-2 text-terracotta">Select a category below to filter the lookbook.</span>
      </p>
    </div>
  </header>

  <!-- Infinite Running Text Marquee Ribbon -->
  <div class="w-full overflow-hidden border-y border-text/5 bg-card-bg/40 py-4 mb-16 select-none pointer-events-none z-10 relative">
    <div class="flex whitespace-nowrap animate-marquee">
      <!-- Tape 1 -->
      <div class="flex text-[9px] tracking-[0.3em] uppercase text-terracotta font-sans shrink-0">
        <span class="mx-8">Italian Aesthetics</span>
        <span class="mx-8">•</span>
        <span class="mx-8">Bags</span>
        <span class="mx-8">•</span>
        <span class="mx-8">Dresses</span>
        <span class="mx-8">•</span>
      </div>
      <!-- Tape 2 (seamless duplication) -->
      <div class="flex text-[9px] tracking-[0.3em] uppercase text-terracotta font-sans shrink-0">
        <span class="mx-8">Italian Aesthetics</span>
        <span class="mx-8">•</span>
        <span class="mx-8">Bags</span>
        <span class="mx-8">•</span>
        <span class="mx-8">Dresses</span>
        <span class="mx-8">•</span>
      </div>
    </div>
  </div>

  <!-- Category Filter Controls -->
  <nav class="flex flex-wrap justify-center items-center gap-x-8 gap-y-4 max-w-4xl mx-auto px-6 mb-16 border-b border-text/5 pb-8">
    <button 
      class="filter-btn text-[9px] tracking-[0.25em] uppercase border-b border-text pb-1 font-semibold text-text transition-all duration-300 cursor-pointer" 
      data-filter="all"
    >
      All Looks
    </button>
    {
      categories.map(category => (
        <button 
          class="filter-btn text-[9px] tracking-[0.25em] uppercase border-b border-transparent pb-1 text-text/40 hover:text-text transition-all duration-300 cursor-pointer" 
          data-filter={category}
        >
          {category}
        </button>
      ))
    }
  </nav>

  <!-- Lookbook Grid Section -->
  <section class="max-w-7xl mx-auto px-6 md:px-16 mb-24">
    {lookbookData.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-20 text-center animate-fade-in-up">
        <h2 class="font-serif text-3xl font-normal text-text mb-4">New collections dropping soon...</h2>
        <p class="font-sans text-xs text-text/60 tracking-[0.1em] uppercase">We are curating the finest aesthetic luxury pieces. Check back shortly.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-20 gap-x-10">
        {
          lookbookData.map((item, index) => {
            const cardEl = (
              <ProductCard
                id={item.id}
                title={item.title}
                category={item.category}
                price={item.price}
                imageUrl={item.imageUrl}
                rawUrl={item.rawUrl}
                alt={item.alt}
              />
            );

            // We insert a beautiful full-width AdSlot banner after the 3rd look item (index 2)
            if (index === 2) {
              return (
                <>
                  {cardEl}
                  <AdSlot 
                    quote="Simplicity is the keynote of all true elegance." 
                    author="Coco Chanel" 
                    ctaText="Explore Curation Partnerships"
                  />
                </>
              );
            }

            return cardEl;
          })
        }
      </div>
    )}
  </section>
</Layout>

<script>
  // Client-side grid filtering and staggered scroll reveal animations
  const initFiltersAndReveal = () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.lookbook-card');
    const adSlots = document.querySelectorAll('.lookbook-ad-slot');
    const reveals = document.querySelectorAll('.reveal');

    // Setup IntersectionObserver for scroll-reveal
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          revealObserver.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      threshold: 0.08,
      rootMargin: '0px 0px -40px 0px'
    });

    // Observe and apply staggered animation delay indices
    reveals.forEach((el, index) => {
      const gridIndex = index % 3;
      el.classList.remove('reveal-delay-100', 'reveal-delay-200', 'reveal-delay-300');
      
      if (gridIndex === 1) {
        el.classList.add('reveal-delay-100');
      } else if (gridIndex === 2) {
        el.classList.add('reveal-delay-200');
      }
      
      revealObserver.observe(el);
    });

    // Setup filtering listeners
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Reset button states
        filterButtons.forEach(b => {
          b.classList.remove('border-text', 'font-semibold', 'text-text');
          b.classList.add('border-transparent', 'text-text/40');
        });

        // Set active button state
        btn.classList.add('border-text', 'font-semibold', 'text-text');
        btn.classList.remove('border-transparent', 'text-text/40');

        const filter = btn.getAttribute('data-filter');

        // Toggle card visibility
        cards.forEach((card, index) => {
          const category = card.getAttribute('data-category');
          const element = card as HTMLElement;
          
          if (filter === 'all' || category === filter) {
            element.style.display = 'flex';
            // Re-trigger cascade fade-in animation
            element.classList.remove('active');
            
            // Adjust delays based on filtered items
            element.classList.remove('reveal-delay-100', 'reveal-delay-200');
            const newIndex = index % 3;
            if (newIndex === 1) {
              element.classList.add('reveal-delay-100');
            } else if (newIndex === 2) {
              element.classList.add('reveal-delay-200');
            }

            setTimeout(() => {
              element.classList.add('active');
            }, 50);
          } else {
            element.style.display = 'none';
            element.classList.remove('active');
          }
        });

        // Toggle ad slots visibility
        adSlots.forEach(slot => {
          const element = slot as HTMLElement;
          if (filter === 'all') {
            element.style.display = 'flex';
            element.classList.remove('active');
            setTimeout(() => {
              element.classList.add('active');
            }, 50);
          } else {
            element.style.display = 'none';
            element.classList.remove('active');
          }
        });
      });
    });
  };

  // Run on page load
  initFiltersAndReveal();

  // Run on swap if utilizing Astro transitions
  document.addEventListener('astro:after-swap', initFiltersAndReveal);
</script>
