---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Élévation">
  <div class="max-w-3xl mx-auto px-6 py-20 md:py-32">
    <h1 class="font-serif text-4xl md:text-5xl tracking-tight mb-8">About Élévation</h1>
    <div class="font-sans text-sm md:text-base text-text/80 leading-relaxed space-y-6">
      <p>
        Welcome to Élévation. We are a digital lookbook dedicated to curating the finest premium resort wear, bohemian chic dresses, and aesthetic luxury handbags. Our mission is to elevate your everyday wardrobe by connecting you with high-quality, timeless fashion pieces from trusted global retailers.
      </p>
    </div>
  </div>
</Layout>
