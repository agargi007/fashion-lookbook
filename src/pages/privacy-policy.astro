---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy & Affiliate Disclosure">
  <div class="max-w-3xl mx-auto px-6 py-20 md:py-32">
    <h1 class="font-serif text-4xl md:text-5xl tracking-tight mb-8">Privacy Policy & Affiliate Disclosure</h1>
    <div class="font-sans text-sm md:text-base text-text/80 leading-relaxed space-y-8">
      <section class="space-y-4">
        <h2 class="font-serif text-2xl tracking-tight">Privacy Policy</h2>
        <p>
          This Privacy Policy describes how Élévation collects and uses information.
        </p>
      </section>
      
      <section class="space-y-4">
        <h2 class="font-serif text-2xl tracking-tight">Affiliate Disclosure</h2>
        <p>
          Élévation operates as a curated shopping platform and participates in various affiliate marketing programs. This means that when you click on links to various merchants on this site and make a purchase, this can result in a commission that is credited to this site. This comes at no additional cost to you and helps keep our platform running.
        </p>
      </section>
    </div>
  </div>
</Layout>
